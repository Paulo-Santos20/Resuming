# Variáveis Públicas (enviadas ao client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Variáveis Server-Side (NUNCA expostas ao client)
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Email sending is done per-user via Gmail API (OAuth token from login)

# Gemini API (múltiplas chaves separadas por vírgula para key rotation)
GEMINI_API_KEY=

# Groq API (1º fallback gratuito)
GROQ_API_KEY=

# DeepSeek API (2º fallback, ~$0.14/M tokens)
DEEPSEEK_API_KEY=

# Python Service (Cloud Run)
CLOUD_RUN_URL=http://localhost:8000
